# База данных (Supabase / Neon PostgreSQL)
DATABASE_URL="postgresql://postgres:***@your_db_host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:***@your_db_host:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_openssl_rand_base64_32"

# Google OAuth
GOOGLE_CLIENT_ID="your_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_client_secret"

# MuAPI AI
MUAPIAPP_API_KEY="your_muapi_api_key"
WEBHOOK_URL="your_public_url_for_callbacks"

# ЮKassa (приём платежей в РФ)
YOOKASSA_SHOP_ID="your_shop_id"
YOOKASSA_SECRET_KEY="your_secret_key"

# Telegram Bot (FitBot)
TELEGRAM_BOT_TOKEN="your_bot_token_from_botfather"
FITBOT_SECRET="generate_random_secret_here"