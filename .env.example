# Database Configuration (Supabase/Neon PostgreSQL)
DATABASE_URL="postgresql://postgres:***@your_db_host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:***@your_db_host:5432/postgres"

# NextAuth Settings
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_generated_using_openssl_rand_base64_32"

# Google Cloud OAuth Credentials
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# MuAPI AI Generation Configuration
MUAPIAPP_API_KEY="your_muapi_api_key_from_muapi.ai"
WEBHOOK_URL="your_public_ngrok_or_domain_url_for_async_callbacks"

# Stripe Payments Configuration
STRIPE_SECRET_KEY="sk_tes..._key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# Stripe Subscription Price IDs (создай продукты в Stripe Dashboard)
STRIPE_PRICE_LIGHT="price_your_light_monthly_id"
STRIPE_PRICE_PRO="price_your_pro_monthly_id"
STRIPE_PRICE_UNLIMITED="price_your_unlimited_monthly_id"
